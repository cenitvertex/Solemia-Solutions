{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "solemia-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/solemia-web", "dev"],
      "port": 5173,
      "env": {
        "PORT": "5173",
        "BASE_PATH": "/",
        "MSYS_NO_PATHCONV": "1"
